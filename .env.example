# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=aiops_user
DB_PASSWORD=your_secure_password_here
DB_NAME=aiops

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Environment
NODE_ENV=development

# Backend API
API_BASE_URL=http://localhost:3000

# Sentry (Optional)
SENTRY_DSN=your_sentry_dsn_here

# Xiaohongshu Credentials (For Publisher)
XIAOHONGSHU_EMAIL=your_email_here
XIAOHONGSHU_PASSWORD=your_password_here

# Crawler Settings
CRAWL_INTERVAL_HOURS=6
PUBLISH_INTERVAL_HOURS=4
GENERATE_CONTENT_INTERVAL_HOURS=12

# Publisher Settings
PUBLISH_BATCH_SIZE=3
PUBLISH_DELAY_MINUTES=60
